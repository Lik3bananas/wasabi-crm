# --- LOGGING ---
LOG_LEVEL=INFO                      # DEBUG, INFO, WARNING, ERROR
LOG_FILE=/var/log/wasabi/sync.log

# --- ENCRYPTION (Para CPF, telefone sensível) ---
ENCRYPTION_KEY=GERAR_COM_cryptography.fernet
ENCRYPTION_ALGORITHM=AES-256

# --- FEATURE FLAGS ---
FEATURE_INCREMENTAL_SYNC=true
FEATURE_AUTO_DEDUPLICATION=true
FEATURE_AUDIT_LOGGING=true

# ============================================================================
# INSTRUÇÕES DE PREENCHIMENTO
# ============================================================================
#
# 1. DATABASE:
#    - DB_ENDPOINT: Obtém na AWS RDS Dashboard
#    - DB_PASSWORD: Gerar com: openssl rand -base64 32
#
# 2. AWS:
#    - Obtém em AWS IAM (credenciais do usuário)
#
# 3. WEBSITE_API:
#    - Definir conforme plataforma (WooCommerce, Shopify, etc)
#    - Valores obtêm com o cliente
#
# 4. ENCRYPTION_KEY:
#    - Gerar com:
#      python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#    - GUARDAR ESTA CHAVE! Se perder, não consegue descriptografar CPF
