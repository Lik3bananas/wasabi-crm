# --- WEBSITE API (Preencher após definir plataforma) ---
WEBSITE_API_PROVIDER=woocommerce    # ou shopify, custom
WEBSITE_API_BASE_URL=https://seuloja.com/wp-json/wc/v3
WEBSITE_API_KEY=ck_XXXXXXXXXXXXX
WEBSITE_API_SECRET=cs_XXXXXXXXXXXXX
WEBSITE_API_TIMEOUT=30
WEBSITE_SYNC_FREQUENCY=daily        # daily, hourly

# --- NOTIFICATIONS (Email para alertas) ---
EMAIL_ALERTS_ENABLED=false
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SENDER=alerts@wasabi.com.br
EMAIL_PASSWORD=senha_app_google
